---
interface Props {
  status?: string;
  title?: string;
  variant?: 'cyan' | 'purple' | 'emerald' | 'rose';
  class?: string;
  id?: string;
  backdrop?: boolean;
}

const { 
  status, 
  title, 
  variant = 'emerald', 
  class: className = '', 
  id,
  backdrop = true
} = Astro.props;

const styles = {
  cyan: {
    border: 'border-cyan-500/10 shadow-[0_0_50px_rgba(6,182,212,0.05)]',
    bracket: 'border-cyan-400/40',
    text: 'text-cyan-400'
  },
  purple: {
    border: 'border-purple-500/15 shadow-[0_0_50px_rgba(168,85,247,0.06)]',
    bracket: 'border-purple-400/40',
    text: 'text-purple-400'
  },
  emerald: {
    border: 'border-emerald-500/15 shadow-[0_0_50px_rgba(16,185,129,0.06)]',
    bracket: 'border-emerald-400/40',
    text: 'text-emerald-400'
  },
  rose: {
    border: 'border-rose-500/15 shadow-[0_0_50px_rgba(244,63,94,0.06)]',
    bracket: 'border-rose-400/40',
    text: 'text-rose-400'
  }
}[variant];
const hasPosition = className.includes('absolute') || className.includes('fixed') || className.includes('relative');
---

<div id={id} class={`${hasPosition ? '' : 'relative'} border rounded-xl overflow-hidden ${backdrop ? 'backdrop-blur-lg bg-slate-950/40' : 'bg-[#03030c]/95'} ${styles.border} ${className}`}>
  <div class={`absolute top-0 left-0 w-4 h-4 border-t border-l rounded-tl-xl ${styles.bracket}`}></div>
  <div class={`absolute top-0 right-0 w-4 h-4 border-t border-r rounded-tr-xl ${styles.bracket}`}></div>
  <div class={`absolute bottom-0 left-0 w-4 h-4 border-b border-l rounded-bl-xl ${styles.bracket}`}></div>
  <div class={`absolute bottom-0 right-0 w-4 h-4 border-b border-r rounded-br-xl ${styles.bracket}`}></div>

  {status && (
    <div class="flex items-center justify-between text-[9px] font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2 select-none">
      <span class={styles.text}>[ STATUS: {status} ]</span>
      {title && <span class="text-slate-500">{title}</span>}
    </div>
  )}

  <slot />
</div>
