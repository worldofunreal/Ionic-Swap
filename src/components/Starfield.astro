<div class="starry-background absolute inset-0 overflow-hidden w-full h-full pointer-events-none z-0">
  <canvas id="starfield" class="w-full h-full block bg-transparent opacity-85"></canvas>
</div>

<script>
  let n = 1200;
  let w = window.innerWidth;
  let h = window.innerHeight;
  let x = w / 2;
  let y = h / 2;
  let z = (w + h) / 2;
  let star_ratio = 256;
  let starSpeed = 0.4;
  let star = new Array(n);
  let context: CanvasRenderingContext2D | null = null;

  interface ShootingStar {
    x: number;
    y: number;
    dx: number;
    dy: number;
    speed: number;
    opacity: number;
    active: boolean;
  }
  const shootingStars: ShootingStar[] = [];
  const maxShootingStars = 3;

  function spawnShootingStar() {
    let star = shootingStars.find(s => !s.active);
    if (!star) {
      if (shootingStars.length < maxShootingStars) {
        star = { x: 0, y: 0, dx: 0, dy: 0, speed: 0, opacity: 0, active: false };
        shootingStars.push(star);
      } else {
        return;
      }
    }

    star.x = Math.random() * w;
    star.y = Math.random() * (h * 0.5); 
    const angle = Math.PI / 6 + Math.random() * (Math.PI / 12); 
    star.speed = 15 + Math.random() * 10; 
    star.dx = Math.cos(angle) * star.speed;
    star.dy = Math.sin(angle) * star.speed;
    star.opacity = 1.0;
    star.active = true;
  }

  function init() {
    w = window.innerWidth;
    h = window.innerHeight;
    x = w / 2;
    y = h / 2;
    z = (w + h) / 2;

    const starfield = document.getElementById('starfield') as HTMLCanvasElement;
    if (!starfield) return;

    starfield.width = w;
    starfield.height = h;
    context = starfield.getContext('2d');
    if (context) {
      context.strokeStyle = 'rgba(180, 220, 255, 0.8)';
      context.globalAlpha = 0.8;
    }

    for (let i = 0; i < n; i++) {
      star[i] = new Array(5);
      star[i][0] = Math.random() * w * 2 - x * 2;
      star[i][1] = Math.random() * h * 2 - y * 2;
      star[i][2] = Math.round(Math.random() * z);
      star[i][3] = 0;
      star[i][4] = 0;
    }
  }

  function anim() {
    if (!context) return;
    context.clearRect(0, 0, w, h);
    
    context.fillStyle = "rgba(0, 15, 5, 0.1)";
    context.fillRect(0, 0, w, h);

    const time = Date.now() * 0.0003;
    const glowX = w / 2 + Math.sin(time) * 50;
    const glowY = h / 2 + Math.cos(time * 0.8) * 30;
    const nebula = context.createRadialGradient(glowX, glowY, w * 0.1, w / 2, h / 2, Math.max(w, h));
    nebula.addColorStop(0, 'rgba(34, 197, 94, 0.04)'); // Green core
    nebula.addColorStop(0.5, 'rgba(16, 185, 129, 0.02)'); // Emerald mid-layer
    nebula.addColorStop(1, 'transparent');
    context.fillStyle = nebula;
    context.fillRect(0, 0, w, h);
    
    for (let i = 0; i < n; i++) {
      let star_x_save = star[i][3];
      let star_y_save = star[i][4];
      star[i][2] -= starSpeed;
      if (star[i][2] > z) star[i][2] -= z;
      if (star[i][2] < 0) star[i][2] += z;
      star[i][3] = x + (star[i][0] / star[i][2]) * star_ratio;
      star[i][4] = y + (star[i][1] / star[i][2]) * star_ratio;
      
      if (
        star_x_save > 0 &&
        star_x_save < w &&
        star_y_save > 0 &&
        star_y_save < h
      ) {
        const brightness = 1 - (star[i][2] / z) * 0.9;
        context.lineWidth = brightness * 1.5;
        context.strokeStyle = `rgba(180, 220, 255, ${brightness})`;
        context.beginPath();
        context.moveTo(star_x_save, star_y_save);
        context.lineTo(star[i][3], star[i][4]);
        context.stroke();
      }
    }

    if (Math.random() < 0.006) {
      spawnShootingStar();
    }

    shootingStars.forEach(s => {
      if (!s.active) return;
      s.x += s.dx;
      s.y += s.dy;
      s.opacity -= 0.02;

      if (s.opacity <= 0 || s.x < 0 || s.x > w || s.y < 0 || s.y > h) {
        s.active = false;
        return;
      }

      context.strokeStyle = `rgba(180, 220, 255, ${s.opacity})`;
      context.lineWidth = 1.5;
      context.beginPath();
      context.moveTo(s.x, s.y);
      context.lineTo(s.x - s.dx * 1.5, s.y - s.dy * 1.5);
      context.stroke();
    });

    requestAnimationFrame(anim);
  }

  window.addEventListener('resize', () => {
    init();
  });

  init();
  anim();
</script>

<style>
  .starry-background {
    background: radial-gradient(circle at center, #020703 0%, #000100 100%);
  }
</style>
