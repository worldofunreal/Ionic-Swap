<style>
  :global(body) {
    overflow: hidden !important;
    height: 100vh !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Fade-in animations for module views */
  .module-view {
    display: none;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  }

  .module-view.active {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.8; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.02); }
  }

  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
</style>

<script>
  // ponytail: unified state router and reactive controllers in under 120 lines
  const navItems = document.querySelectorAll('.nav-item');
  const modules = document.querySelectorAll('.module-view');
  const emeraldGlow = document.getElementById('nebula-emerald');

  // Module Router
  navItems.forEach(item => {
    item.addEventListener('click', () => {
      const target = item.getAttribute('data-target');
      
      // Update sidebar visual states
      navItems.forEach(nav => {
        nav.classList.remove('text-emerald-400', 'bg-emerald-500/10', 'border', 'border-emerald-400/20');
        nav.classList.add('text-slate-400');
      });
      item.classList.add('text-emerald-400', 'bg-emerald-500/10', 'border', 'border-emerald-400/20');
      item.classList.remove('text-slate-400');

      // Swap active panels
      modules.forEach(mod => {
        mod.classList.remove('active');
      });
      const targetPanel = document.getElementById(`panel-${target}`);
      if (targetPanel) {
        targetPanel.classList.add('active');
      }
    });
  });

  // Dual card tilt effect
  window.addEventListener('mousemove', (e) => {
    const halfW = window.innerWidth / 2;
    const halfH = window.innerHeight / 2;
    const rotateX = -((e.clientY - halfH) / halfH) * 4; 
    const rotateY = ((e.clientX - halfW) / halfW) * 4;
    
    modules.forEach(mod => {
      if (mod.classList.contains('active')) {
        const cards = mod.querySelectorAll('.rounded-xl');
        cards.forEach(card => {
          (card as HTMLElement).style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
        });
      }
    });

    const dx = (e.clientX - halfW) * 0.015;
    const dy = (e.clientY - halfH) * 0.015;
    if (emeraldGlow) emeraldGlow.style.transform = `translate(${dx}px, ${dy}px)`;
  }, { passive: true });

  window.addEventListener('mouseleave', () => {
    modules.forEach(mod => {
      const cards = mod.querySelectorAll('.rounded-xl');
      cards.forEach(card => {
        (card as HTMLElement).style.transform = 'rotateX(0deg) rotateY(0deg)';
      });
    });
    if (emeraldGlow) emeraldGlow.style.transform = 'translate(0px, 0px)';
  });

  // Clipboard copy with animated status toasts
  const toast = document.getElementById('toast');
  const toastMsg = document.getElementById('toast-message');
  let toastTimeout: NodeJS.Timeout;

  const showToast = (message: string) => {
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.remove('hidden');
      toast.classList.add('flex');
      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.add('hidden');
        toast.classList.remove('flex');
      }, 2500);
    }
  };

  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const addr = btn.getAttribute('data-address') || '';
      navigator.clipboard.writeText(addr).then(() => {
        showToast(`Copied Address: ${addr.slice(0, 10)}...`);
      });
      e.stopPropagation();
    });
  });

  // Trading panel calculator
  const tradeBuyInput = document.getElementById('trade-buy-input') as HTMLInputElement;
  const tradeEstReceive = document.getElementById('trade-est-receive');
  const percentBtns = document.querySelectorAll('.percent-btn');

  const btcPrice = 58451.25;

  const calculateTrade = () => {
    const val = parseFloat(tradeBuyInput.value) || 0;
    if (tradeEstReceive) {
      tradeEstReceive.innerText = (val / btcPrice).toFixed(6);
    }
  };

  tradeBuyInput?.addEventListener('input', calculateTrade);

  percentBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const percent = parseFloat(btn.getAttribute('data-val') || '0');
      const maxBalance = 1250;
      tradeBuyInput.value = ((maxBalance * percent) / 100).toFixed(2);
      calculateTrade();
    });
  });

  // Staking lock multiplier calculator
  const stakeInput = document.getElementById('stake-input') as HTMLInputElement;
  const stakeDuration = document.getElementById('stake-duration') as HTMLInputElement;
  const lblVotingPower = document.getElementById('lbl-voting-power');
  const lblAnnualYield = document.getElementById('lbl-annual-yield');

  const calculateStake = () => {
    const val = parseFloat(stakeInput.value) || 0;
    const dur = parseFloat(stakeDuration.value) || 1;
    
    if (lblVotingPower) {
      lblVotingPower.innerText = (val * dur).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    if (lblAnnualYield) {
      lblAnnualYield.innerText = (val * dur * 0.0625).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
  };

  stakeInput?.addEventListener('input', calculateStake);
  stakeDuration?.addEventListener('input', calculateStake);

  // Buttons triggers
  document.getElementById('btn-execute-trade')?.addEventListener('click', () => {
    showToast("Gasless Order submitted to IONOS validator.");
  });

  document.getElementById('btn-execute-stake')?.addEventListener('click', () => {
    showToast("Tokens locked. Staking voting power registered.");
  });

  document.querySelectorAll('.quick-trade-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const row = btn.closest('tr');
      if (row) {
        const symbol = row.getAttribute('data-symbol') || 'BTC';
        const priceText = row.children[1].textContent || '$1.00';
        
        // Update trade panel symbol/chart header
        const chartPair = document.getElementById('chart-pair');
        if (chartPair) chartPair.innerText = `${symbol}/USDT`;
        
        const tradeSymbol = document.getElementById('trade-symbol');
        if (tradeSymbol) tradeSymbol.innerText = symbol;

        // Switch panel to trade
        const tradeNav = document.querySelector('button[data-target="trade"]') as HTMLButtonElement;
        tradeNav?.click();
      }
      e.stopPropagation();
    });
  });
</script>
