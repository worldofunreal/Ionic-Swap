<style>
  :global(body) {
    overflow: hidden !important;
    height: 100vh !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Smooth panels transitions */
  .module-view {
    display: none;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease-out, transform 0.2s ease-out;
  }

  .module-view.active {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // ponytail: unified gray/zinc dashboard controller in under 115 lines
  const navItems = document.querySelectorAll('.nav-item');
  const modules = document.querySelectorAll('.module-view');

  // Router mechanism
  navItems.forEach(item => {
    item.addEventListener('click', () => {
      const target = item.getAttribute('data-target');

      // Update sidebar states
      navItems.forEach(nav => {
        nav.classList.remove('text-emerald-500', 'bg-emerald-500/10', 'dark:bg-emerald-500/5', 'border', 'border-emerald-400/20');
        nav.classList.add('text-zinc-500', 'dark:text-zinc-400');
      });
      item.classList.add('text-emerald-500', 'bg-emerald-500/10', 'dark:bg-emerald-500/5', 'border', 'border-emerald-400/20');
      item.classList.remove('text-zinc-500', 'dark:text-zinc-400');

      // Update active panel views
      modules.forEach(mod => {
        mod.classList.remove('active');
      });
      const targetPanel = document.getElementById(`panel-${target}`);
      if (targetPanel) {
        targetPanel.classList.add('active');
      }
    });
  });

  // Slide carousel controls
  let activeSlide = 0;
  const carouselTrack = document.getElementById('carousel-track');
  const dots = document.querySelectorAll('.carousel-dot');

  const updateCarousel = (slideIndex: number) => {
    if (carouselTrack) {
      carouselTrack.style.transform = `translateX(-${slideIndex * 100}%)`;
      dots.forEach((dot, idx) => {
        if (idx === slideIndex) {
          dot.classList.add('bg-emerald-500');
          dot.classList.remove('bg-zinc-300', 'dark:bg-zinc-700');
        } else {
          dot.classList.remove('bg-emerald-500');
          dot.classList.add('bg-zinc-300', 'dark:bg-zinc-700');
        }
      });
      activeSlide = slideIndex;
    }
  };

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const slide = parseInt(dot.getAttribute('data-slide') || '0');
      updateCarousel(slide);
    });
  });

  // Auto scroll carousel every 6 seconds
  setInterval(() => {
    const nextSlide = (activeSlide + 1) % 2; // We have 2 slides
    updateCarousel(nextSlide);
  }, 6000);

  // General notification triggers
  const toast = document.getElementById('toast');
  const toastMsg = document.getElementById('toast-message');
  let toastTimeout: NodeJS.Timeout;

  const showNotification = (message: string) => {
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.remove('hidden');
      toast.classList.add('flex');
      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.add('hidden');
        toast.classList.remove('flex');
      }, 2500);
    }
  };

  document.querySelectorAll('.address-copy-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const addr = btn.getAttribute('data-address') || '';
      navigator.clipboard.writeText(addr).then(() => {
        showNotification(`Copied address: ${addr.slice(0, 10)}...`);
      });
      e.stopPropagation();
    });
  });

  // Staking multiplier calculations
  const stakeInput = document.getElementById('liq-stake-input') as HTMLInputElement;
  const stakeDuration = document.getElementById('liq-stake-duration') as HTMLInputElement;
  const lblPower = document.getElementById('lbl-voting-power-display');
  const lblYield = document.getElementById('lbl-annual-yield-display');

  const calculateStaking = () => {
    const val = parseFloat(stakeInput.value) || 0;
    const dur = parseFloat(stakeDuration.value) || 1;

    if (lblPower) {
      lblPower.innerText = (val * dur).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    if (lblYield) {
      lblYield.innerText = (val * dur * 0.0625).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
  };

  stakeInput?.addEventListener('input', calculateStaking);
  stakeDuration?.addEventListener('input', calculateStaking);

  // Trading panel calculator
  const payInput = document.getElementById('pay-amount-input') as HTMLInputElement;
  const receiveVal = document.getElementById('lbl-receive-val');
  const tradePercentBtns = document.querySelectorAll('.trade-percent-btn');
  const coinPrices: Record<string, number> = { BTC: 58451.25, ETH: 3120.40, SOL: 142.25, ICP: 8.91 };

  let currentTargetSymbol = 'BTC';

  const updateTradeCalculator = () => {
    const val = parseFloat(payInput.value) || 0;
    const price = coinPrices[currentTargetSymbol] || 58451.25;
    if (receiveVal) {
      receiveVal.innerText = (val / price).toFixed(6);
    }
  };

  payInput?.addEventListener('input', updateTradeCalculator);

  tradePercentBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const percent = parseFloat(btn.getAttribute('data-val') || '0');
      const maxUSDTBalance = 1250;
      payInput.value = ((maxUSDTBalance * percent) / 100).toFixed(2);
      updateTradeCalculator();
    });
  });

  // Actions trigger triggers
  document.getElementById('btn-submit-swap')?.addEventListener('click', () => {
    showNotification("Swap submitted. Subsidy applied.");
  });

  document.getElementById('btn-approve-stake')?.addEventListener('click', () => {
    showNotification("Staking locked successfully.");
  });

  // Action links routers
  document.querySelectorAll('.price-row, .markets-trade-btn, .quick-trade-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const row = btn.closest('tr') || btn.closest('.price-row');
      if (row) {
        const symbol = row.getAttribute('data-symbol') || 'BTC';
        currentTargetSymbol = symbol;

        // Update trade panel details
        const headerTitle = document.getElementById('trade-chart-title');
        if (headerTitle) headerTitle.innerText = `${symbol}/USDT`;

        const receiveSym = document.getElementById('lbl-receive-sym');
        if (receiveSym) receiveSym.innerText = symbol;

        updateTradeCalculator();

        // Router to trade tab
        const tradeNav = document.querySelector('button[data-target="trade"]') as HTMLButtonElement;
        tradeNav?.click();
      }
      e.stopPropagation();
    });
  });

  document.querySelectorAll('.nav-to-trade').forEach(btn => {
    btn.addEventListener('click', () => {
      const tradeNav = document.querySelector('button[data-target="trade"]') as HTMLButtonElement;
      tradeNav?.click();
    });
  });

  // Theme switcher trigger
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const html = document.documentElement;
    if (html.classList.contains('dark')) {
      html.classList.remove('dark');
      localStorage.setItem('ionic-swap-theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('ionic-swap-theme', 'dark');
    }
  });

  // Read theme on load
  const prefTheme = localStorage.getItem('ionic-swap-theme') || 'dark';
  if (prefTheme === 'dark') {
    document.documentElement.classList.add('dark');
  } else {
    document.documentElement.classList.remove('dark');
  }
</script>
