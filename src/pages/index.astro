---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
---

<Layout title="IONIC SWAP | Multi-Chain Gasless Exchange Cockpit">
  <!-- Viewport Locked Main Container -->
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex bg-[#030704] text-white font-sans select-none z-10">
    <!-- Canvas animated space background -->
    <Starfield />

    <!-- Cyberpunk Scanline overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.15)_50%),linear-gradient(90deg,rgba(34,197,94,0.015),rgba(0,0,0,0.1),rgba(16,185,129,0.015))] bg-[size:100%_4px,6px_100%] pointer-events-none z-0 opacity-20"></div>
    <div class="absolute inset-0 bg-radial from-transparent via-[#010301]/80 to-[#000]/95 pointer-events-none z-0"></div>

    <!-- LEFT SIDEBAR: Standard Expanding Navigation -->
    <aside id="sidebar" class="hidden md:flex flex-col justify-between items-center z-50 fixed top-0 left-0 h-screen bg-[#020502]/90 border-r border-emerald-500/10 w-16 hover:w-52 transition-all duration-300 ease-out group backdrop-blur-md">
      <!-- Top Logo -->
      <div class="w-full flex items-center justify-start p-4 gap-3 select-none border-b border-white/5 h-16">
        <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-400/30 flex items-center justify-center flex-shrink-0">
          <span class="text-emerald-400 font-bold font-mono">I</span>
        </div>
        <span class="text-sm font-black font-mono tracking-widest text-white uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">IONIC_SWAP</span>
      </div>

      <!-- Center navigation icons -->
      <nav class="w-full flex-1 flex flex-col gap-1 py-4 px-2">
        <!-- Markets -->
        <button data-target="markets" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-emerald-400 bg-emerald-500/10 border border-emerald-400/20 hover:text-white transition-all duration-200 text-left">
          <span class="text-lg font-mono leading-none">🧭</span>
          <span class="text-[10px] font-bold font-mono tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">MARKETS</span>
        </button>

        <!-- Trade -->
        <button data-target="trade" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-slate-400 hover:bg-white/5 hover:text-white transition-all duration-200 text-left mt-1">
          <span class="text-lg font-mono leading-none">📈</span>
          <span class="text-[10px] font-bold font-mono tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">TRADE</span>
        </button>

        <!-- Wallet -->
        <button data-target="wallet" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-slate-400 hover:bg-white/5 hover:text-white transition-all duration-200 text-left mt-1">
          <span class="text-lg font-mono leading-none">💼</span>
          <span class="text-[10px] font-bold font-mono tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">WALLET</span>
        </button>

        <!-- Liquidity -->
        <button data-target="liquidity" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-slate-400 hover:bg-white/5 hover:text-white transition-all duration-200 text-left mt-1">
          <span class="text-lg font-mono leading-none">🧪</span>
          <span class="text-[10px] font-bold font-mono tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">LIQUIDITY</span>
        </button>
      </nav>

      <!-- Bottom Settings indicator -->
      <div class="w-full p-4 border-t border-white/5 flex items-center justify-start gap-3 h-16">
        <span class="text-lg leading-none select-none">⚙️</span>
        <span class="text-[9px] font-mono text-slate-500 uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-200">SYSTEM: v3.1.2</span>
      </div>
    </aside>

    <!-- RIGHT SECTION: Main Console Area -->
    <div class="flex-1 flex flex-col min-h-screen md:ml-16 relative">
      
      <!-- TOP HEADER -->
      <header class="w-full h-16 border-b border-white/5 px-6 flex items-center justify-between z-10 backdrop-blur-md bg-[#020502]/40 select-none">
        <div class="flex flex-col">
          <div class="flex items-center space-x-2">
            <span class="text-sm font-bold tracking-widest text-emerald-400 font-mono uppercase">EXCHANGE_CONOPS</span>
            <span class="text-[8px] bg-emerald-500/10 border border-emerald-400/20 text-emerald-400 px-1.5 py-0.5 rounded font-mono">[ ACTIVE_TUNNEL ]</span>
          </div>
          <span class="text-[7px] text-slate-500 font-mono tracking-widest leading-none mt-0.5">PEER_NODES: IONOS + LOCAL_STANDBY</span>
        </div>

        <!-- Connection / User Avatar -->
        <div class="flex items-center space-x-4">
          <div id="wallet-connected" class="flex items-center space-x-3 bg-[#050e06]/60 border border-emerald-500/25 pl-3 pr-2 py-1 rounded-xl backdrop-blur-md cursor-pointer group hover:border-emerald-400/40 transition-colors">
            <div class="flex flex-col text-right font-mono">
              <span class="text-[9px] font-bold text-white leading-none">PLAYER_0x1337</span>
              <span class="text-[7px] text-emerald-400 tracking-wider leading-none flex items-center justify-end gap-1 mt-0.5">
                <span class="inline-block w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
                ICP_MAINNET
              </span>
            </div>
            <!-- Custom user icon mock -->
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-emerald-400 to-teal-600 border border-emerald-400/30 flex items-center justify-center text-white font-mono font-bold text-xs select-none">
              BIZ
            </div>
          </div>
        </div>
      </header>

      <!-- CENTER DISPLAY CONTAINER -->
      <div class="flex-1 overflow-hidden p-6 relative">

        <!-- 🧭 MODULE 1: DISCOVERY & MARKETS -->
        <div id="panel-markets" class="module-view active w-full h-full flex flex-col justify-between" style="perspective: 1000px;">
          <!-- Master Grid Layout -->
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 flex-1 min-h-0">
            <!-- Left side: Market Overview & Token Grid -->
            <div class="lg:col-span-3 flex flex-col gap-4 overflow-hidden h-full">
              <!-- Glassmorphic Card Panel container -->
              <div class="relative border border-emerald-500/10 rounded-xl bg-slate-950/40 backdrop-blur-lg flex-1 flex flex-col overflow-hidden p-6">
                <!-- Cyber Brackets -->
                <div class="absolute top-0 left-0 w-4 h-4 border-t border-l rounded-tl-xl border-emerald-400/30"></div>
                <div class="absolute top-0 right-0 w-4 h-4 border-t border-r rounded-tr-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l rounded-bl-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r rounded-br-xl border-emerald-400/30"></div>

                <!-- Card header status -->
                <div class="flex items-center justify-between text-[9px] font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
                  <span class="text-emerald-400">[ STATUS: ASSET_CATALOG ]</span>
                  <span class="text-slate-500">MARKET_BOARDS</span>
                </div>

                <!-- Price Catalog Table -->
                <div class="flex-1 overflow-y-auto scrollbar-thin pr-1 text-left select-text">
                  <table class="w-full font-mono text-xs text-left">
                    <thead>
                      <tr class="border-b border-white/5 text-slate-500 text-[10px] tracking-widest">
                        <th class="py-2.5 font-light">ASSET</th>
                        <th class="py-2.5 font-light text-right">PRICE</th>
                        <th class="py-2.5 font-light text-right">24H_CHANGE</th>
                        <th class="py-2.5 font-light text-right">MARKET_CAP</th>
                        <th class="py-2.5 font-light text-right">ACTION</th>
                      </tr>
                    </thead>
                    <tbody id="markets-table-body" class="divide-y divide-white/5">
                      <!-- BTC -->
                      <tr class="hover:bg-white/5 transition-colors group cursor-pointer" data-symbol="BTC">
                        <td class="py-3 flex items-center gap-2">
                          <span class="text-lg">🪙</span>
                          <div>
                            <div class="font-bold text-white">BTC</div>
                            <span class="text-[9px] text-slate-500">Bitcoin</span>
                          </div>
                        </td>
                        <td class="py-3 text-right font-bold text-white leading-none">$58,451.25</td>
                        <td class="py-3 text-right text-emerald-400 font-bold">+4.12%</td>
                        <td class="py-3 text-right text-slate-400">$1.15T</td>
                        <td class="py-3 text-right">
                          <button class="quick-trade-btn px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 hover:bg-emerald-500/25 text-emerald-400 font-bold rounded-lg text-[10px] tracking-wider uppercase transition-all duration-300">TRADE</button>
                        </td>
                      </tr>
                      <!-- ETH -->
                      <tr class="hover:bg-white/5 transition-colors group cursor-pointer" data-symbol="ETH">
                        <td class="py-3 flex items-center gap-2">
                          <span class="text-lg">🔷</span>
                          <div>
                            <div class="font-bold text-white">ETH</div>
                            <span class="text-[9px] text-slate-500">Ethereum</span>
                          </div>
                        </td>
                        <td class="py-3 text-right font-bold text-white leading-none">$3,120.40</td>
                        <td class="py-3 text-right text-emerald-400 font-bold">+2.84%</td>
                        <td class="py-3 text-right text-slate-400">$374.5B</td>
                        <td class="py-3 text-right">
                          <button class="quick-trade-btn px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 hover:bg-emerald-500/25 text-emerald-400 font-bold rounded-lg text-[10px] tracking-wider uppercase transition-all duration-300">TRADE</button>
                        </td>
                      </tr>
                      <!-- SOL -->
                      <tr class="hover:bg-white/5 transition-colors group cursor-pointer" data-symbol="SOL">
                        <td class="py-3 flex items-center gap-2">
                          <span class="text-lg">☀️</span>
                          <div>
                            <div class="font-bold text-white">SOL</div>
                            <span class="text-[9px] text-slate-500">Solana</span>
                          </div>
                        </td>
                        <td class="py-3 text-right font-bold text-white leading-none">$142.25</td>
                        <td class="py-3 text-right text-emerald-400 font-bold">+8.25%</td>
                        <td class="py-3 text-right text-slate-400">$66.4B</td>
                        <td class="py-3 text-right">
                          <button class="quick-trade-btn px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 hover:bg-emerald-500/25 text-emerald-400 font-bold rounded-lg text-[10px] tracking-wider uppercase transition-all duration-300">TRADE</button>
                        </td>
                      </tr>
                      <!-- ICP -->
                      <tr class="hover:bg-white/5 transition-colors group cursor-pointer" data-symbol="ICP">
                        <td class="py-3 flex items-center gap-2">
                          <span class="text-lg">♾️</span>
                          <div>
                            <div class="font-bold text-white">ICP</div>
                            <span class="text-[9px] text-slate-500">Internet Computer</span>
                          </div>
                        </td>
                        <td class="py-3 text-right font-bold text-white leading-none">$8.91</td>
                        <td class="py-3 text-right text-rose-500 font-bold">-1.15%</td>
                        <td class="py-3 text-right text-slate-400">$4.1B</td>
                        <td class="py-3 text-right">
                          <button class="quick-trade-btn px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 hover:bg-emerald-500/25 text-emerald-400 font-bold rounded-lg text-[10px] tracking-wider uppercase transition-all duration-300">TRADE</button>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Right side: Discovery Carousel and DeFi 101 Guide -->
            <div class="lg:col-span-1 flex flex-col gap-4 overflow-hidden h-full">
              <!-- DeFi 101 Panel -->
              <div class="relative border border-emerald-500/10 rounded-xl bg-slate-950/40 backdrop-blur-lg flex-1 flex flex-col p-6 text-left">
                <!-- Cyber Brackets -->
                <div class="absolute top-0 left-0 w-4 h-4 border-t border-l rounded-tl-xl border-emerald-400/30"></div>
                <div class="absolute top-0 right-0 w-4 h-4 border-t border-r rounded-tr-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l rounded-bl-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r rounded-br-xl border-emerald-400/30"></div>

                <div class="flex items-center justify-between text-[9px] font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
                  <span class="text-emerald-400">[ ACADEMY ]</span>
                  <span class="text-slate-500">GUIDE</span>
                </div>

                <div class="flex-1 overflow-y-auto scrollbar-thin pr-1 space-y-4">
                  <div class="space-y-1">
                    <span class="text-[8px] font-mono text-emerald-400">[ STAGE_01 ]</span>
                    <h4 class="text-xs font-bold text-white uppercase tracking-tight">GASLESS_SWAPPING_EXPLAINED</h4>
                    <p class="text-[10px] text-slate-400 leading-normal">Our relay nodes pay the execution fee directly on the target network, shielding the player's account from holding gas assets.</p>
                  </div>
                  <div class="space-y-1">
                    <span class="text-[8px] font-mono text-emerald-400">[ STAGE_02 ]</span>
                    <h4 class="text-xs font-bold text-white uppercase tracking-tight">ZFS_ORTHOGONAL_MUTATIONS</h4>
                    <p class="text-[10px] text-slate-400 leading-normal">Your state directories write block changes directly to ZFS pool segments, which are mirrored in atomic micro-bursts to backup jails.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>


        <!-- 📈 MODULE 2: TRADING CONSOLE -->
        <div id="panel-trade" class="module-view w-full h-full flex flex-col justify-between" style="perspective: 1000px;">
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 flex-1 min-h-0">
            <!-- Left side: Live Charting Panel -->
            <div class="lg:col-span-3 flex flex-col gap-4 overflow-hidden h-full">
              <!-- Candle chart Panel -->
              <div class="relative border border-emerald-500/10 rounded-xl bg-slate-950/40 backdrop-blur-lg flex-1 flex flex-col p-6">
                <!-- Cyber Brackets -->
                <div class="absolute top-0 left-0 w-4 h-4 border-t border-l rounded-tl-xl border-emerald-400/30"></div>
                <div class="absolute top-0 right-0 w-4 h-4 border-t border-r rounded-tr-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l rounded-bl-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r rounded-br-xl border-emerald-400/30"></div>

                <div class="flex items-center justify-between text-[9px] font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
                  <span class="text-emerald-400">[ CHART_GRAPH_FEED ]</span>
                  <span id="chart-pair" class="text-white font-bold font-mono">BTC/USDT</span>
                </div>

                <!-- High-Fidelity SVG chart mock -->
                <div class="flex-1 w-full bg-black/40 border border-white/5 rounded-lg overflow-hidden relative flex items-end p-2 select-none">
                  <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <path d="M0,100 L0,80 L20,70 L40,82 L60,40 L80,55 L100,15 L100,100 Z" fill="url(#chart-grad)"></path>
                    <path d="M0,80 L20,70 L40,82 L60,40 L80,55 L100,15" fill="none" stroke="#22c55e" stroke-width="2" vector-effect="non-scaling-stroke"></path>
                    <circle cx="100" cy="15" r="3" fill="#22c55e" class="animate-pulse"></circle>
                  </svg>
                  <div class="absolute bottom-2 left-2 text-[8px] font-mono text-slate-500">LIVE FEED: BINANCE COCKPIT</div>
                </div>
              </div>
            </div>

            <!-- Right side: Trading Inputs Panel -->
            <div class="lg:col-span-1 flex flex-col gap-4 overflow-hidden h-full text-left">
              <!-- Trade cockpit forms -->
              <div class="relative border border-emerald-500/10 rounded-xl bg-slate-950/40 backdrop-blur-lg flex-1 flex flex-col p-6">
                <!-- Cyber Brackets -->
                <div class="absolute top-0 left-0 w-4 h-4 border-t border-l rounded-tl-xl border-emerald-400/30"></div>
                <div class="absolute top-0 right-0 w-4 h-4 border-t border-r rounded-tr-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l rounded-bl-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r rounded-br-xl border-emerald-400/30"></div>

                <div class="flex items-center justify-between text-[9px] font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
                  <span class="text-emerald-400">[ ORDER_DECK ]</span>
                  <span class="text-slate-500">COCKPIT_FORM</span>
                </div>

                <div class="space-y-4 font-mono text-[9px] flex-1 flex flex-col justify-between">
                  <!-- Inputs container -->
                  <div class="space-y-3">
                    <div class="p-2.5 bg-white/5 border border-white/5 rounded-lg flex justify-between items-center">
                      <div class="flex flex-col">
                        <span class="text-slate-500 uppercase">BUY AMOUNT (USDT)</span>
                        <input id="trade-buy-input" type="number" value="100" class="bg-transparent border-none text-sm font-bold text-white outline-none w-full p-0 leading-none mt-1 focus:ring-0" />
                      </div>
                      <span class="text-slate-400 font-bold">USDT</span>
                    </div>

                    <div class="flex gap-1">
                      <button class="percent-btn flex-1 py-1 bg-white/5 border border-white/5 hover:bg-emerald-500/10 hover:border-emerald-400/20 text-slate-400 hover:text-emerald-400 rounded-lg text-center" data-val="25">25%</button>
                      <button class="percent-btn flex-1 py-1 bg-white/5 border border-white/5 hover:bg-emerald-500/10 hover:border-emerald-400/20 text-slate-400 hover:text-emerald-400 rounded-lg text-center" data-val="50">50%</button>
                      <button class="percent-btn flex-1 py-1 bg-white/5 border border-white/5 hover:bg-emerald-500/10 hover:border-emerald-400/20 text-slate-400 hover:text-emerald-400 rounded-lg text-center" data-val="75">75%</button>
                      <button class="percent-btn flex-1 py-1 bg-white/5 border border-white/5 hover:bg-emerald-500/10 hover:border-emerald-400/20 text-slate-400 hover:text-emerald-400 rounded-lg text-center" data-val="100">100%</button>
                    </div>

                    <div class="text-[8px] text-slate-500 flex justify-between px-1">
                      <span>EST. RECEIVE: <span id="trade-est-receive" class="text-white font-bold">1.71</span> <span id="trade-symbol">BTC</span></span>
                      <span>BAL: 1,250.00 USDT</span>
                    </div>
                  </div>

                  <!-- Execute Action Button -->
                  <button id="btn-execute-trade" class="w-full py-3 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-white font-black tracking-widest uppercase rounded-xl shadow-[0_0_20px_rgba(16,185,129,0.15)] transition-all duration-300 transform active:scale-95 text-center">
                    EXECUTE GASLESS TRADE
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>


        <!-- 💼 MODULE 3: WALLET PORTFOLIO -->
        <div id="panel-wallet" class="module-view w-full h-full flex flex-col justify-between" style="perspective: 1000px;">
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 flex-1 min-h-0">
            <!-- Left side: Portfolio values & Addresses hub -->
            <div class="lg:col-span-2 flex flex-col gap-4 overflow-hidden h-full text-left">
              <!-- Wallet general card -->
              <div class="relative border border-emerald-500/10 rounded-xl bg-slate-950/40 backdrop-blur-lg flex-1 flex flex-col p-6">
                <!-- Cyber Brackets -->
                <div class="absolute top-0 left-0 w-4 h-4 border-t border-l rounded-tl-xl border-emerald-400/30"></div>
                <div class="absolute top-0 right-0 w-4 h-4 border-t border-r rounded-tr-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l rounded-bl-xl border-emerald-400/30"></div>
                <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r rounded-br-xl border-emerald-400/30"></div>

                <div class="flex items-center justify-between text-[9px] font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
                  <span class="text-emerald-400">[ PORTFOLIO_VAL ]</span>
                  <span class="text-slate-500">OVERVIEW_BOARDS</span>
                </div>

                <div class="font-mono flex-1 flex flex-col justify-between">
                  <!-- Money stats -->
                  <div>
                    <span class="text-xs text-slate-500 uppercase tracking-widest">NET WORTH ESTIMATE</span>
                    <div class="text-4xl font-black text-white leading-none mt-1 select-all">$124,582.00</div>
                    <span class="text-[9px] text-emerald-400 font-bold flex items-center gap-1 mt-1"><span class="inline-block w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span> +12.42% APY TRACKING</span>
                  </div>

                  <!-- Multi chain address register -->
                  <div class="space-y-2 mt-4 text-[9px]">
                    <span class="text-[8px] text-emerald-400 tracking-wider">[ CRYPTOGRAPHIC_VAULTS ]</span>
                    
                    <!-- ICP -->
                    <div class="flex items-center justify-between p-2 rounded bg-white/5 border border-white/5 hover:border-emerald-500/20 transition-all duration-300">
                      <span class="text-slate-400 flex items-center gap-1.5">♾️ ICP_PRINCIPAL</span>
                      <div class="flex items-center space-x-2">
                        <span class="text-white font-bold select-all">0x71C...9312</span>
                        <button class="copy-btn hover:text-emerald-400 transition-colors" data-address="0x71C80B0F3A1AB90DE80F3A1AB90DE80F3A1AB90D">📋</button>
                      </div>
                    </div>

                    <!-- EVM -->
                    <div class="flex items-center justify-between p-2 rounded bg-white/5 border border-white/5 hover:border-emerald-500/20 transition-all duration-300">
                      <span class="text-slate-400 flex items-center gap-1.5">🔷 EVM_ADDR</span>
                      <div class="flex items-center space-x-2">
                        <span class="text-white font-bold select-all">0x8a1...3f1c</span>
                        <button class="copy-btn hover:text-emerald-400 transition-colors" data-address="0x8a1a3f1bc09b0b4de9b81cd4265ecc9df74477e41">📋</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right side: Balances List -->
            <div class="lg:col-span-2 flex flex-col gap-4 overflow-hidden h-full text-left">
              <!-- Asset breakdowns -->
              <div class="relative border border-emerald-500/10 rounded-xl bg-slate-950/40 backdrop-blur-lg flex-1 flex flex-col p-6">
                <!-- Cyber Brackets -->
                <div class="absolute top-0 left-0 w-4 h-4 border-t border-l rounded-tl-xl border-emerald-400/30"></div>
                <div class="absolute top-0 right-0 w-4 h-4 border-t border-r rounded-tr-xl border-emerald-400/30"></div>
