---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ionic Swap | Cross-Chain Token Swapping with Gasless Transactions">
  <!-- Viewport-Locked Container -->
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 font-sans select-none z-10">
    
    <!-- LEFT SIDEBAR: Navigational Menu (Collapsible/Expanding) -->
    <aside id="sidebar" class="hidden md:flex flex-col justify-between items-center z-50 fixed top-0 left-0 h-screen bg-zinc-50 dark:bg-[#1e1e24] border-r border-zinc-200 dark:border-zinc-800 w-16 hover:w-52 transition-all duration-300 ease-out group backdrop-blur-md">
      <!-- Brand Logo -->
      <div class="w-full flex items-center justify-start p-4 gap-3 select-none border-b border-zinc-200 dark:border-zinc-800 h-16">
        <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-400/30 flex items-center justify-center flex-shrink-0">
          <!-- Ionic Swap Circle Logo -->
          <svg class="w-5 h-5 text-emerald-500" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="8">
            <path d="M30,50 L50,20 L70,50 L50,80 Z"></path>
            <circle cx="50" cy="50" r="10" fill="currentColor"></circle>
          </svg>
        </div>
        <span class="text-sm font-bold font-mono tracking-widest text-zinc-900 dark:text-white uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">IONIC_SWAP</span>
      </div>

      <!-- Navigation Icons -->
      <nav class="w-full flex-1 flex flex-col gap-1 py-4 px-2">
        <!-- Discovery (Home) -->
        <button data-target="discovery" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-emerald-500 bg-emerald-500/10 dark:bg-emerald-500/5 hover:text-emerald-400 transition-all duration-200 text-left">
          <span class="text-lg leading-none">🧭</span>
          <span class="text-xs font-semibold tracking-wide opacity-0 group-hover:opacity-100 transition-opacity duration-200">Discovery</span>
        </button>

        <!-- Markets -->
        <button data-target="markets" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white transition-all duration-200 text-left">
          <span class="text-lg leading-none">🏦</span>
          <span class="text-xs font-semibold tracking-wide opacity-0 group-hover:opacity-100 transition-opacity duration-200">Markets</span>
        </button>

        <!-- Trade -->
        <button data-target="trade" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white transition-all duration-200 text-left">
          <span class="text-lg leading-none">📈</span>
          <span class="text-xs font-semibold tracking-wide opacity-0 group-hover:opacity-100 transition-opacity duration-200">Trade</span>
        </button>

        <!-- Wallet -->
        <button data-target="wallet" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white transition-all duration-200 text-left">
          <span class="text-lg leading-none">💼</span>
          <span class="text-xs font-semibold tracking-wide opacity-0 group-hover:opacity-100 transition-opacity duration-200">Wallet</span>
        </button>

        <!-- Liquidity -->
        <button data-target="liquidity" class="nav-item w-full flex items-center gap-3 p-3 rounded-lg text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white transition-all duration-200 text-left">
          <span class="text-lg leading-none">🧪</span>
          <span class="text-xs font-semibold tracking-wide opacity-0 group-hover:opacity-100 transition-opacity duration-200">Liquidity</span>
        </button>
      </nav>

      <!-- Bottom Settings/Theme Switcher -->
      <div class="w-full p-4 border-t border-zinc-200 dark:border-zinc-800 flex items-center justify-between h-16 relative">
        <button id="theme-toggle" class="p-2 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors text-zinc-500 dark:text-zinc-400">
          <span class="text-lg leading-none select-none dark:hidden">🌙</span>
          <span class="text-lg leading-none select-none hidden dark:inline">☀️</span>
        </button>
        <span class="text-[9px] font-mono text-zinc-400 dark:text-zinc-500 uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-200">v3.1.2</span>
      </div>
    </aside>

    <!-- RIGHT SECTION: Main Content Frame -->
    <div class="flex-1 flex flex-col min-h-screen md:ml-16 relative overflow-hidden">
      
      <!-- TOP HEADER -->
      <header class="w-full h-16 border-b border-zinc-200 dark:border-zinc-800 px-6 flex items-center justify-between z-10 backdrop-blur-md bg-zinc-100/80 dark:bg-zinc-900/80 select-none">
        <!-- Search bar -->
        <div class="flex items-center flex-1 max-w-md relative">
          <span class="absolute left-3 text-zinc-400">🔍</span>
          <input type="text" placeholder="Search tokens, positions..." class="w-full pl-10 pr-4 py-2 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-800 rounded-lg text-sm text-zinc-900 dark:text-white outline-none focus:ring-2 focus:ring-emerald-500" />
        </div>

        <!-- Right Side: Wallet state & Profile -->
        <div class="flex items-center space-x-4">
          <div id="btn-login-trigger" class="flex items-center space-x-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 pl-3 pr-2 py-1.5 rounded-xl cursor-pointer hover:bg-zinc-100 dark:hover:bg-zinc-750 transition-all">
            <div class="flex flex-col text-right font-sans">
              <span class="text-[10px] font-bold text-zinc-900 dark:text-white leading-none">BIZKIT_0x1337</span>
              <span class="text-[8px] text-emerald-500 font-bold tracking-wider leading-none flex items-center justify-end gap-1 mt-1">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                ICP_MAINNET
              </span>
            </div>
            <!-- Custom Avatar -->
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 border border-emerald-400/20 flex items-center justify-center text-white font-bold text-xs select-none">
              U
            </div>
          </div>
        </div>
      </header>

      <!-- CENTER DISPLAY CONTAINER -->
      <div class="flex-1 overflow-hidden p-6 relative">

        <!-- 🧭 MODULE 1: DISCOVERY (HOME) -->
        <div id="panel-discovery" class="module-view active w-full h-full flex flex-col justify-between overflow-y-auto scrollbar-thin pr-1">
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 flex-1 min-h-0">
            <!-- Left side: DiscoverCarousel & DeFi 101 -->
            <div class="lg:col-span-3 flex flex-col gap-6 text-left h-full">
              
              <!-- DiscoverCarousel -->
              <div class="relative w-full overflow-hidden bg-zinc-50 dark:bg-zinc-800 rounded-2xl border border-zinc-200 dark:border-zinc-850 shadow-sm p-8" style="height: 340px;">
                <!-- Slides Container -->
                <div id="carousel-track" class="h-full flex transition-transform duration-500 ease-in-out w-full">
                  
                  <!-- Slide 1: Cross-Chain Swaps -->
                  <div class="w-full flex-shrink-0 flex flex-col justify-between h-full" style="min-width: 100%;">
                    <div class="flex justify-between items-start">
                      <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-emerald-500/10 dark:bg-emerald-500/5 flex items-center justify-center text-lg text-emerald-500">🔄</div>
                        <div>
                          <h3 class="text-lg font-bold text-zinc-900 dark:text-white">Cross-Chain Swaps</h3>
                          <p class="text-xs text-zinc-500">Seamless token swapping across multiple blockchains</p>
                        </div>
                      </div>
                      <div class="text-right">
                        <div class="text-xl font-bold text-emerald-500">$2.4M</div>
                        <div class="text-[10px] text-zinc-400">Total Volume (24h)</div>
                      </div>
                    </div>
                    <!-- Middle -->
                    <div class="text-center my-auto">
                      <div class="text-3xl font-bold text-zinc-900 dark:text-white">11 SUPPORTED COINS</div>
                      <div class="text-sm text-zinc-500 mt-1">EVM • Solana • Internet Computer</div>
                    </div>
                    <!-- Bottom -->
                    <div class="flex justify-between items-center">
                      <span class="text-xs text-emerald-500 font-bold">+12.5% Today</span>
                      <button class="nav-to-trade px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded-lg transition-colors">Start Swapping ➔</button>
                    </div>
                  </div>

                  <!-- Slide 2: Gasless Transactions -->
                  <div class="w-full flex-shrink-0 flex flex-col justify-between h-full" style="min-width: 100%;">
                    <div class="flex justify-between items-start">
                      <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-emerald-500/10 dark:bg-emerald-500/5 flex items-center justify-center text-lg text-emerald-500">⚡</div>
                        <div>
                          <h3 class="text-lg font-bold text-zinc-900 dark:text-white">Gasless Transactions</h3>
                          <p class="text-xs text-zinc-500">Swap tokens without paying gas fees</p>
                        </div>
                      </div>
                      <div class="text-right">
                        <div class="text-xl font-bold text-emerald-500">98%</div>
                        <div class="text-[10px] text-zinc-400">Gasless Success Rate</div>
                      </div>
                    </div>
                    <!-- Middle -->
                    <div class="text-center my-auto">
                      <div class="text-3xl font-bold text-zinc-900 dark:text-white">1,247 ACTIVE USERS</div>
                      <div class="text-sm text-zinc-500 mt-1">Gasless swaps routed today</div>
                    </div>
                    <!-- Bottom -->
                    <div class="flex justify-between items-center">
                      <span class="text-xs text-emerald-500 font-bold">+8.3% Volume</span>
                      <button class="nav-to-trade px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded-lg transition-colors">Launch Swap ➔</button>
                    </div>
                  </div>

                </div>
                <!-- Carousel Dots Indicator -->
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                  <button class="carousel-dot w-2 h-2 rounded-full bg-emerald-500" data-slide="0"></button>
                  <button class="carousel-dot w-2 h-2 rounded-full bg-zinc-300 dark:bg-zinc-700" data-slide="1"></button>
                </div>
              </div>

              <!-- DeFi 101 section -->
              <div class="space-y-3">
                <div>
                  <h3 class="text-md font-bold text-zinc-900 dark:text-white">DeFi 101</h3>
                  <p class="text-xs text-zinc-400">Learn about tokens, standards, and cross-chain swapping</p>
                </div>
                <!-- Articles horizontal list -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  
                  <!-- Article 1 -->
                  <div class="bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-850 p-4 rounded-xl flex flex-col justify-between hover:scale-[1.02] transition-transform cursor-pointer h-40">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center text-lg text-emerald-500">💵</div>
                      <div>
                        <h4 class="text-xs font-bold text-zinc-900 dark:text-white uppercase tracking-tight">What are Tokens?</h4>
                        <span class="text-[10px] text-zinc-400">Digital Assets</span>
                      </div>
                    </div>
                    <p class="text-[10px] text-zinc-500 leading-normal mt-2">Learn about different types of tokens, standards, and multichain assets.</p>
                    <span class="text-[10px] font-bold text-emerald-500 mt-3 block">Learn More ➔</span>
                  </div>

                  <!-- Article 2 -->
                  <div class="bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-850 p-4 rounded-xl flex flex-col justify-between hover:scale-[1.02] transition-transform cursor-pointer h-40">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center text-lg text-emerald-500">⚙️</div>
                      <div>
                        <h4 class="text-xs font-bold text-zinc-900 dark:text-white uppercase tracking-tight">Token Standards</h4>
                        <span class="text-[10px] text-zinc-400">ERC-20, SPL, ICRC</span>
                      </div>
                    </div>
                    <p class="text-[10px] text-zinc-500 leading-normal mt-2">Explore the token standards used on Ethereum, Solana, and Internet Computer.</p>
                    <span class="text-[10px] font-bold text-emerald-500 mt-3 block">Learn More ➔</span>
                  </div>

                  <!-- Article 3 -->
                  <div class="bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-850 p-4 rounded-xl flex flex-col justify-between hover:scale-[1.02] transition-transform cursor-pointer h-40">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center text-lg text-emerald-500">⚡</div>
                      <div>
                        <h4 class="text-xs font-bold text-zinc-900 dark:text-white uppercase tracking-tight">Gasless Power</h4>
                        <span class="text-[10px] text-zinc-400">Zero Fee Swaps</span>
                      </div>
                    </div>
                    <p class="text-[10px] text-zinc-500 leading-normal mt-2">Understand the mechanics behind our ultra-efficient gasless routing technology.</p>
                    <span class="text-[10px] font-bold text-emerald-500 mt-3 block">Learn More ➔</span>
                  </div>

                </div>
              </div>
            </div>

            <!-- Right side: TokenPriceList -->
            <div class="lg:col-span-1 flex flex-col gap-4 h-full text-left">
              <div class="bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-850 rounded-2xl p-6 flex flex-col h-full overflow-hidden">
                <h3 class="text-md font-bold text-zinc-900 dark:text-white mb-4">Token Prices</h3>
                <div class="flex-1 overflow-y-auto scrollbar-thin pr-1 space-y-3">
                  
                  <!-- Token Row BTC -->
                  <div class="price-row flex items-center justify-between p-2 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer" data-symbol="BTC">
                    <div class="flex items-center gap-2">
                      <span class="text-lg">🪙</span>
                      <div>
                        <div class="font-bold text-zinc-900 dark:text-white text-xs leading-none">BTC</div>
                        <span class="text-[9px] text-zinc-400">Bitcoin</span>
                      </div>
                    </div>
                    <div class="text-right font-mono">
                      <div class="text-xs font-bold text-zinc-900 dark:text-white">$58,451.25</div>
                      <span class="text-[9px] text-emerald-500 font-bold">+4.12%</span>
                    </div>
                  </div>

                  <!-- Token Row ETH -->
                  <div class="price-row flex items-center justify-between p-2 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer" data-symbol="ETH">
                    <div class="flex items-center gap-2">
                      <span class="text-lg">🔷</span>
                      <div>
                        <div class="font-bold text-zinc-900 dark:text-white text-xs leading-none">ETH</div>
                        <span class="text-[9px] text-zinc-400">Ethereum</span>
                      </div>
                    </div>
                    <div class="text-right font-mono">
                      <div class="text-xs font-bold text-zinc-900 dark:text-white">$3,120.40</div>
                      <span class="text-[9px] text-emerald-500 font-bold">+2.84%</span>
                    </div>
                  </div>

                  <!-- Token Row SOL -->
                  <div class="price-row flex items-center justify-between p-2 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer" data-symbol="SOL">
                    <div class="flex items-center gap-2">
                      <span class="text-lg">☀️</span>
                      <div>
                        <div class="font-bold text-zinc-900 dark:text-white text-xs leading-none">SOL</div>
                        <span class="text-[9px] text-zinc-400">Solana</span>
                      </div>
                    </div>
                    <div class="text-right font-mono">
                      <div class="text-xs font-bold text-zinc-900 dark:text-white">$142.25</div>
                      <span class="text-[9px] text-emerald-500 font-bold">+8.25%</span>
                    </div>
                  </div>

                  <!-- Token Row ICP -->
                  <div class="price-row flex items-center justify-between p-2 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer" data-symbol="ICP">
                    <div class="flex items-center gap-2">
                      <span class="text-lg">♾️</span>
                      <div>
                        <div class="font-bold text-zinc-900 dark:text-white text-xs leading-none">ICP</div>
                        <span class="text-[9px] text-zinc-400">Internet Computer</span>
                      </div>
                    </div>
                    <div class="text-right font-mono">
                      <div class="text-xs font-bold text-zinc-900 dark:text-white">$8.91</div>
                      <span class="text-[9px] text-rose-500 font-bold">-1.15%</span>
                    </div>
                  </div>

                </div>
              </div>
            </div>
          </div>
        </div>


        <!-- 🏦 MODULE 2: MARKETS -->
        <div id="panel-markets" class="module-view w-full h-full flex flex-col justify-between overflow-y-auto scrollbar-thin pr-1">
          <div class="grid grid-cols-1 gap-6 flex-1 min-h-0 text-left">
            <div class="bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-850 rounded-2xl p-6 flex flex-col">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-md font-bold text-zinc-900 dark:text-white">Coin Asset catalog</h3>
                <span class="text-xs text-zinc-400">Live feeds via Binance WS API</span>
              </div>
              
              <table class="w-full text-sm font-sans">
                <thead>
                  <tr class="border-b border-zinc-200 dark:border-zinc-700 text-zinc-400 text-xs text-left">
                    <th class="py-3 font-semibold">COIN</th>
                    <th class="py-3 font-semibold text-right">PRICE</th>
                    <th class="py-3 font-semibold text-right">TODAY'S PNL</th>
                    <th class="py-3 font-semibold text-right">ACTION</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-200 dark:divide-zinc-700">
                  
                  <!-- Row 1 -->
                  <tr class="hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors">
                    <td class="py-4 flex items-center gap-3">
                      <span class="text-2xl">🪙</span>
                      <div>
                        <div class="font-bold text-zinc-900 dark:text-white">BTC</div>
                        <span class="text-xs text-zinc-400">Bitcoin</span>
                      </div>
                    </td>
                    <td class="py-4 text-right font-mono font-bold text-zinc-900 dark:text-white">$58,451.25</td>
                    <td class="py-4 text-right font-mono font-bold text-emerald-500">+4.12%</td>
                    <td class="py-4 text-right">
                      <button class="markets-trade-btn px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-semibold rounded-lg transition-colors" data-symbol="BTC">Trade</button>
                    </td>
                  </tr>

                  <!-- Row 2 -->
                  <tr class="hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors">
                    <td class="py-4 flex items-center gap-3">
                      <span class="text-2xl">🔷</span>
                      <div>
                        <div class="font-bold text-zinc-900 dark:text-white">ETH</div>
                        <span class="text-xs text-zinc-400">Ethereum</span>
                      </div>
                    </td>
                    <td class="py-4 text-right font-mono font-bold text-zinc-900 dark:text-white">$3,120.40</td>
                    <td class="py-4 text-right font-mono font-bold text-emerald-500">+2.84%</td>
                    <td class="py-4 text-right">
                      <button class="markets-trade-btn px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-semibold rounded-lg transition-colors" data-symbol="ETH">Trade</button>
                    </td>
                  </tr>

                  <!-- Row 3 -->
                  <tr class="hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors">
                    <td class="py-4 flex items-center gap-3">
                      <span class="text-2xl">☀️</span>
                      <div>
                        <div class="font-bold text-zinc-900 dark:text-white">SOL</div>
                        <span class="text-xs text-zinc-400">Solana</span>
                      </div>
                    </td>
                    <td class="py-4 text-right font-mono font-bold text-zinc-900 dark:text-white">$142.25</td>
                    <td class="py-4 text-right font-mono font-bold text-emerald-500">+8.25%</td>
                    <td class="py-4 text-right">
                      <button class="markets-trade-btn px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-semibold rounded-lg transition-colors" data-symbol="SOL">Trade</button>
                    </td>
                  </tr>

                </tbody>
              </table>
            </div>
          </div>
        </div>


        <!-- 📈 MODULE 3: TRADE -->
        <div id="panel-trade" class="module-view w-full h-full flex flex-col justify-between overflow-hidden">
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 flex-1 min-h-0 text-left">
            <!-- Candlestick Chart block -->
            <div class="lg:col-span-3 flex flex-col gap-4 overflow-hidden h-full">
              <div class="bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-850 rounded-2xl p-6 flex flex-col h-full overflow-hidden">
                <div class="flex justify-between items-center mb-4">
                  <div class="flex items-center gap-3">
                    <h3 id="trade-chart-title" class="text-md font-bold text-zinc-900 dark:text-white">BTC/USDT</h3>
                    <span class="text-xs font-mono text-emerald-500 font-bold animate-pulse">$58,451.25 (+4.12%)</span>
                  </div>
                  <div class="flex gap-1">
                    <button class="px-2 py-1 bg-zinc-100 dark:bg-zinc-900 hover:bg-emerald-500/10 text-emerald-500 text-[10px] font-bold rounded">1m</button>
                    <button class="px-2 py-1 bg-zinc-100 dark:bg-zinc-900 hover:bg-emerald-500/10 text-emerald-500 text-[10px] font-bold rounded">5m</button>
                    <button class="px-2 py-1 bg-zinc-100 dark:bg-zinc-900 hover:bg-emerald-500/10 text-emerald-500 text-[10px] font-bold rounded border border-emerald-500/20">15m</button>
                    <button class="px-2 py-1 bg-zinc-100 dark:bg-zinc-900 hover:bg-emerald-500/10 text-emerald-500 text-[10px] font-bold rounded">1h</button>
                  </div>
                </div>

                <!-- High quality vector candlesticks simulation -->
                <div class="flex-1 w-full border border-zinc-200 dark:border-zinc-700 bg-zinc-100 dark:bg-zinc-900 rounded-xl overflow-hidden relative flex items-end p-2 select-none">
                  <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <!-- Grid Lines -->
                    <line x1="0" y1="25" x2="100" y2="25" stroke="rgba(156,163,175,0.08)" stroke-width="1"></line>
                    <line x1="0" y1="50" x2="100" y2="50" stroke="rgba(156,163,175,0.08)" stroke-width="1"></line>
                    <line x1="0" y1="75" x2="100" y2="75" stroke="rgba(156,163,175,0.08)" stroke-width="1"></line>
                    
                    <!-- Candlesticks bars (green/red) -->
                    <!-- Green Candle 1 -->
