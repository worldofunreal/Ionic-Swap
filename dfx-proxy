server {
    listen 7777 ssl;
    server_name ionicswap.com;
    
    # Use existing Let's Encrypt certificate
    ssl_certificate /etc/letsencrypt/live/ionicswap.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ionicswap.com/privkey.pem;
    
    # SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    
    location / {
        proxy_pass http://localhost:4943;
        proxy_set_header Host uxrrr-q7777-77774-qaaaq-cai.raw.localhost:4943;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
    }
}